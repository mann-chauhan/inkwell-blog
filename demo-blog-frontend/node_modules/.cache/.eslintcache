rontend/src/App.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/reportWebVitals.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/store/auth-context.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/Pages.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Header/Header.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/i18n/index.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/LoginPage.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/MainPage.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/RegisterPage.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/NewPostPage.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/UserProfilePage.js",["125"],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Pages/PostPage.js",["126"],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/ScrollToTop.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Banner.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Loading.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/CommentsList.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/lib/api.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Forms/RegistrationForm.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Forms/LoginForm.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Forms/NewPostForm.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Forms/PostUpdateForm.js",[],[],"/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Forms/NewCommentForm.js",["127"],[],"import React, { useContext, useEffect, useRef, useState } from \"react\";\nimport { Formik } from \"formik\";\nimport * as Yup from \"yup\";\nimport Banner from \"../Banner\";\nimport AuthContext from \"../../store/auth-context\";\nimport { submitNewComment } from \"../../lib/api\";\nimport { useTranslation } from \"react-i18next\";\n\nconst NewCommentForm = ({ postId, onContentChange }) => {\n  const [isSubmitted, setIsSubmitted] = useState(false);\n  const authCtx = useContext(AuthContext);\n  const textAreaRef = useRef(null);\n  const { t } = useTranslation();\n\n  const onSubmit = (comment, formikHelpers) => {\n    setTimeout(() => {\n      submitNewComment({ id: postId, ...comment }, authCtx.token)\n        .then(() => { formikHelpers.resetForm(); setIsSubmitted(true); })\n        .catch(console.log)\n        .finally(() => formikHelpers.setSubmitting(false));\n    }, 2000);\n  };\n\n  useEffect(() => {\n    setTimeout(() => {\n      if (isSubmitted) { setIsSubmitted(false); onContentChange(); }\n    }, 2000);\n  }, [isSubmitted]);\n\n  useEffect(() => {\n    if (textAreaRef.current) textAreaRef.current.style.height = \"100px\";\n  });\n\n  return (\n    <Formik\n      initialValues={{ content: \"\" }}\n      validationSchema={Yup.object({\n        content: Yup.string()\n          .min(5, t(\"validation:atLeast\", { number: 5 }))\n          .max(1000, t(\"validation:lessThan\", { number: 1000 }))\n          .required(t(\"validation:required\")),\n      })}\n      onSubmit={onSubmit}\n    >\n      {(formik) => (\n        <>\n          <div className=\"ink-new-comment-card\">\n            <form onSubmit={formik.handleSubmit}>\n              <div className=\"ink-form-group\" style={{ marginBottom: \"0.75rem\" }}>\n                <label className=\"ink-form-label\">{t(\"addNewComment\")}</label>\n                <textarea\n                  ref={textAreaRef}\n                  name=\"content\"\n                  className=\"ink-comment-textarea\"\n                  placeholder={t(\"addNewComment\") + \"…\"}\n                  onChange={formik.handleChange}\n                  onBlur={formik.handleBlur}\n                  value={formik.values.content}\n                />\n                {formik.touched.content && formik.errors.content && (\n                  <div className=\"ink-form-error\">{formik.errors.content}</div>\n                )}\n              </div>\n              <div style={{ display: \"flex\", justifyContent: \"flex-end\" }}>\n                <button type=\"submit\" className=\"ink-btn\" disabled={formik.isSubmitting}>\n                  {formik.isSubmitting ? \"Posting…\" : t(\"addNewComment\")}\n                </button>\n              </div>\n            </form>\n          </div>\n          {isSubmitted && (\n            <Banner className=\"text-success border-success mb-4\"\n              message={`${t(\"addedBy\", { type: \"comment\" })} ${authCtx.userName}`} />\n          )}\n        </>\n      )}\n    </Formik>\n  );\n};\nexport default NewCommentForm;\n","/Users/mannchauhan/Desktop/This PC/D - Drive/RISE/CollegeProject/Project/inkwell 14/inkwell-blog/demo-blog-frontend/src/Components/Comment.js",["128"],[],"import React, { useContext, useEffect, useRef, useState } from \"react\";\nimport AuthContext from \"../store/auth-context\";\nimport { Formik } from \"formik\";\nimport * as Yup from \"yup\";\nimport Banner from \"./Banner\";\nimport { deleteComment, updateComment } from \"../lib/api\";\nimport { useTranslation } from \"react-i18next\";\n\nfunction getInitials(name) {\n  if (!name) return \"?\";\n  return name.split(\" \").map(w => w[0]).join(\"\").slice(0, 2).toUpperCase();\n}\n\nconst Comment = ({ comment, onContentChange }) => {\n  const [isDeleting, setIsDeleting] = useState(false);\n  const [isDeleted, setIsDeleted] = useState(false);\n  const [isUpdated, setIsUpdated] = useState(false);\n  const [error, setError] = useState(null);\n  const textAreaRef = useRef(null);\n  const authCtx = useContext(AuthContext);\n  const { t } = useTranslation();\n\n  useEffect(() => {\n    if (textAreaRef.current) {\n      textAreaRef.current.style.height = textAreaRef.current.scrollHeight + \"px\";\n    }\n  });\n\n  const canEdit = authCtx.isLoggedIn &&\n    (authCtx.userName === comment.blogUser || authCtx.authorities === authCtx.ROLES.admin);\n\n  const updateHandler = (values, formikHelpers) => {\n    setTimeout(() => {\n      updateComment({ id: comment.id, ...values }, authCtx.token)\n        .then(() => setIsUpdated(true))\n        .catch(e => setError(e))\n        .finally(() => formikHelpers.setSubmitting(false));\n    }, 2000);\n  };\n\n  const deleteHandler = () => {\n    setIsDeleting(true);\n    setTimeout(() => {\n      deleteComment(comment.id, authCtx.token)\n        .then(() => setIsDeleted(true))\n        .catch(e => setError(e))\n        .finally(() => setIsDeleting(false));\n    }, 2000);\n  };\n\n  useEffect(() => {\n    setTimeout(() => {\n      if (isDeleted) { setIsDeleted(false); onContentChange(); }\n      if (isUpdated) { setIsUpdated(false); onContentChange(); }\n      if (error) setError(null);\n    }, 2000);\n  }, [isDeleted, isUpdated, error]);\n\n  return (\n    <Formik\n      initialValues={{ content: comment.comment }}\n      validationSchema={Yup.object({\n        content: Yup.string()\n          .min(5, t(\"validation:atLeast\", { number: 5 }))\n          .max(1000, t(\"validation:lessThan\", { number: 1000 }))\n          .required(t(\"validation:required\")),\n      })}\n      onSubmit={updateHandler}\n    >\n      {(formik) => (\n        <>\n          <div className=\"ink-comment-card\">\n            <div className=\"ink-comment-header\">\n              <div className=\"ink-comment-user\">\n                <div className=\"ink-comment-avatar\">{getInitials(comment.blogUser)}</div>\n                <span className=\"ink-comment-username\">{comment.blogUser}</span>\n              </div>\n              <span className=\"ink-comment-date\">{t(\"commented\")}: {comment.createdOn}</span>\n            </div>\n            <div className=\"ink-comment-body-wrap\">\n              <form onSubmit={formik.handleSubmit}>\n                <textarea\n                  ref={textAreaRef}\n                  name=\"content\"\n                  className=\"ink-comment-textarea\"\n                  onChange={formik.handleChange}\n                  onBlur={formik.handleBlur}\n                  value={formik.values.content}\n                  disabled={formik.isSubmitting || isDeleting || isDeleted || isUpdated}\n                  readOnly={!canEdit}\n                  style={{ overflow: \"hidden\" }}\n                />\n                {formik.touched.content && formik.errors.content && (\n                  <div className=\"ink-form-error\">{formik.errors.content}</div>\n                )}\n                {canEdit && (\n                  <div style={{ display: \"flex\", justifyContent: \"flex-end\", gap: \"0.5rem\", marginTop: \"0.75rem\" }}>\n                    <button type=\"submit\" className=\"ink-btn-ghost\"\n                      disabled={isDeleting || isDeleted || isUpdated}>\n                      {formik.isSubmitting ? \"Saving…\" : t(\"update\")}\n                    </button>\n                    <button type=\"button\" className=\"ink-btn-danger\"\n                      onClick={deleteHandler}\n                      disabled={formik.isSubmitting || isUpdated || isDeleted}>\n                      {isDeleting ? \"Deleting…\" : t(\"delete\")}\n                    </button>\n                  </div>\n                )}\n              </form>\n            </div>\n          </div>\n          {isUpdated && <Banner className=\"text-success border-success mb-4\" message={`${t(\"updatedBy\", { type: \"comment\" })} ${authCtx.userName}`} />}\n          {isDeleted && <Banner className=\"text-danger border-danger mb-4\" message={`${t(\"deleteBy\", { type: \"comment\" })} ${authCtx.userName}`} />}\n          {error && <Banner className=\"text-danger border-danger mb-4\" message={error.message} />}\n        </>\n      )}\n    </Formik>\n  );\n};\nexport default Comment;\n",{"ruleId":"129","severity":1,"message":"130","line":56,"column":6,"nodeType":"131","endLine":56,"endColumn":30,"suggestions":"132"},{"ruleId":"129","severity":1,"message":"133","line":77,"column":6,"nodeType":"131","endLine":77,"endColumn":10,"suggestions":"134"},{"ruleId":"129","severity":1,"message":"135","line":28,"column":6,"nodeType":"131","endLine":28,"endColumn":19,"suggestions":"136"},{"ruleId":"129","severity":1,"message":"135","line":57,"column":6,"nodeType":"131","endLine":57,"endColumn":35,"suggestions":"137"},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'authCtx.token'. Either include it or remove the dependency array.","ArrayExpression",["138"],"React Hook useEffect has a missing dependency: 'fetchPostById'. Either include it or remove the dependency array.",["139"],"React Hook useEffect has a missing dependency: 'onContentChange'. Either include it or remove the dependency array. If 'onContentChange' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["140"],["141"],{"desc":"142","fix":"143"},{"desc":"144","fix":"145"},{"desc":"146","fix":"147"},{"desc":"148","fix":"149"},"Update the dependencies array to be: [username, isOwnProfile, authCtx.token]",{"range":"150","text":"151"},"Update the dependencies array to be: [fetchPostById, id]",{"range":"152","text":"153"},"Update the dependencies array to be: [isSubmitted, onContentChange]",{"range":"154","text":"155"},"Update the dependencies array to be: [isDeleted, isUpdated, error, onContentChange]",{"range":"156","text":"157"},[2030,2054],"[username, isOwnProfile, authCtx.token]",[2668,2672],"[fetchPostById, id]",[996,1009],"[isSubmitted, onContentChange]",[1890,1919],"[isDeleted, isUpdated, error, onContentChange]"]